<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="product_ecommerce_field_view_form_shopify_inherit" model="ir.ui.view">
            <field name="name">product.ecommerce.field.view.form.shopify.inherit</field>
            <field name="model">product.ecommerce.field</field>
            <field name="inherit_id" ref="integration.product_ecommerce_field_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='technical_name']" position="after">
                    <field name="is_shopify_metafield" string="Metafield" widget="boolean_toggle" invisible="type_api != 'shopify'" readonly="is_default"/>
                    <field name="shopify_metafield_type" string="Metafield Type" invisible="type_api != 'shopify' or not is_shopify_metafield" required="is_shopify_metafield" readonly="is_default"/>
                    <field name="translation_key" string="Translation Key" groups="base.group_no_one" invisible="type_api != 'shopify'" readonly="is_default"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
