<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_sale_integration_form" model="ir.ui.view">
            <field name="name">sale.integration.form</field>
            <field name="model">sale.integration</field>
            <field name="inherit_id" ref="integration.view_sale_integration_form"/>
            <field name="arch" type="xml">
                <group name="other" position="inside">
                    <field name="use_customer_currency" invisible="not is_integration_shopify" widget="boolean_toggle"/>
                </group>
                <group name="advanced_sales_order_settings" position="inside">
                    <field name="integration_channel_ids" widget="many2many_tags" invisible="not is_integration_shopify" options="{'no_create': True, 'no_edit': True}"/>
                    <div colspan="2">
                        <button name="import_sale_channels" string="Import Sale Channels" type="object" class="btn btn-primary" invisible="not is_integration_shopify"/>
                    </div>
                </group>
                <page name="sale_order_page" position="inside">
                    <group string="Sale Order Metafields Mappings"
                           name="sale_order_metafields_mappings"
                           invisible="not is_integration_shopify">
                        <div colspan="2">
                            <p>
                                Use the table below to setup mappings between Shopify order metafields and fields on sale.order model in Odoo.
                            </p>
                            <p>
                                <button name="import_metafields"
                                        string="Update Metafields"
                                        type="object"
                                        class="btn btn-primary"
                                        context="{'external_entity': 'order'}"
                                />
                            </p>
                        </div>
                        <field name="order_metafield_mapping_ids" colspan="2" nolabel="1">
                            <list editable="bottom">
                                <field name="integration_id" column_invisible="1"/> <!-- Required because it is used in the fields domains in the model -->
                                <field name="filtered_odoo_fields" column_invisible="1"/> <!-- Required because it is used in the fields domains in the model -->
                                <field name="metafield_id"
                                       domain="[('type', '=', 'order'), ('integration_id', '=', integration_id)]"
                                       options="{'no_open': True, 'no_create': True}"/>
                                <field name="metafield_key"/>
                                <field name="metafield_type"/>
                                <field name="odoo_field_id"
                                       options="{'no_open': True, 'no_create': True}"
                                       required="metafield_id != False"/>
                            </list>
                        </field>
                    </group>
                </page>

                <page name="product_default_page" position="after">
                    <page string="Markets &amp; Catalogs" name="markets_and_catalogs_page" invisible="not is_integration_shopify">
                        <group string="Pricelist and Catalog Mappings" name="pricelist_and_catalog_mappings">
                            <div colspan="2">
                                <div class="alert alert-info" role="alert">
                                    <p class="mb-0">
                                        How Pricelists and Catalogs work
                                    </p>
                                    <ul class="mb-0">
                                        <li>Odoo becomes the master source for all pricing in Shopify.</li>
                                        <li>Prices are generated based on Odoo Pricelists.</li>
                                        <li>When synchronization runs, all Prices in Shopify will be overwritten with values generated from Odoo.</li>
                                        <li>Synchronization runs once per day (if enabled), but you can also trigger it manually.</li>
                                    </ul>
                                </div>
                            </div>
                            <div colspan="2">
                                <group>
                                    <field name="export_prices_cron_id_active"
                                           widget="boolean_toggle"
                                           string="Enable Pricelist Prices Calculation &amp; Export"
                                    />
                                    <p class="o_wrap_label"/><!-- Do not remove - important for layout! -->
                                        <p>
                                            <small>
                                                If enabled, Odoo will automatically calculate and export Pricelist Prices once per day.
                                                If disabled, no prices will be exported automatically, but you can still use the "Send Prices” button on catalogs lines for manual updates.
                                            </small>
                                    </p>
                                    <field name="export_prices_cron_id_lastcall" invisible="not export_prices_cron_id_active"/>
                                    <field name="export_prices_cron_id_nextcall" invisible="not export_prices_cron_id_active"/>
                                </group>
                            </div>
                            <group>
                                <button name="fetch_shopify_catalogs"
                                        string="Import Markets and Catalogs"
                                        type="object"
                                        class="btn-primary  me-2 mb-2"
                                />
                            </group>
                            <div colspan="2">
                                <field name="catalog_line_ids" colspan="2" nolabel="1">
                                    <list editable="bottom">
                                        <field name="integration_id" column_invisible="1"/>
                                        <field name="catalog_id"
                                               domain="[('integration_id', '=', integration_id)]"
                                               options="{'no_create': True}"
                                        />
                                        <field name="pricelist_id"
                                            domain="[('company_id', '=', parent.company_id), ('currency_code', '=', currency_code)]"
                                            required="catalog_id"
                                            readonly="not catalog_id"
                                            options="{'no_create': True}"
                                        />
                                        <field name="pricelist_compare_at_id"
                                            domain="[('company_id', '=', parent.company_id), ('currency_code', '=', currency_code)]"
                                            readonly="not pricelist_id"
                                            options="{'no_create': True}"
                                        />
                                        <button name="action_create_preview_price_batches"
                                                string="Preview"
                                                type="object"
                                                class="btn-outline-primary"
                                                context="{'run_product_pricelist_export': False}"
                                                icon="fa-eye"
                                        />
                                        <button name="create_price_batches_with_delay"
                                                string="Send Prices"
                                                type="object"
                                                class="btn-primary"
                                                context="{'run_product_pricelist_export': True}"
                                                icon="fa-upload"
                                        />
                                    </list>
                                </field>
                            </div>
                        </group>
                    </page>
                </page>

                <page name="customer_default_page" position="inside">
                    <group string="Customer Metafields Mappings"
                           name="customer_metafields_mappings"
                           invisible="not is_integration_shopify">
                        <div colspan="2">
                            <p>
                                Use the table below to setup mappings between Shopify customer metafields and fields on res.partner model in Odoo.
                            </p>
                            <p>
                                <button name="import_metafields"
                                        string="Update Metafields"
                                        type="object"
                                        class="btn btn-primary"
                                        context="{'external_entity': 'customer'}"
                                />
                            </p>
                        </div>
                        <field name="customer_metafield_mapping_ids" colspan="2" nolabel="1">
                            <list editable="bottom">
                                <field name="integration_id" column_invisible="1"/> <!-- Required because it is used in the fields domains in the model -->
                                <field name="filtered_odoo_fields" column_invisible="1"/> <!-- Required because it is used in the fields domains in the model -->
                                <field name="metafield_id"
                                       domain="[('type', '=', 'customer'), ('integration_id', '=', integration_id)]"
                                       options="{'no_open': True, 'no_create': True}"/>
                                <field name="metafield_key"/>
                                <field name="metafield_type"/>
                                <field name="odoo_field_id"
                                       options="{'no_open': True, 'no_create': True}"
                                       required="metafield_id != False"/>
                            </list>
                        </field>
                    </group>
                </page>

                <field name="ignore_vat_validation" position="after">
                    <field name="shopify_customer_language" invisible="not is_integration_shopify"/>
                </field>

                <!-- Shopify-specific sale pricelist warning message -->
                <xpath expr="//span[@name='sale-pricelist-warning']" position="attributes">
                    <attribute name="invisible">is_integration_shopify</attribute>
                </xpath>

                <xpath expr="//span[@name='sale-pricelist-warning']" position="after">
                    <span class="border-start border-warning border-2 d-block ps-2 sale-pricelist-warning" invisible="not is_integration_shopify">
                        <strong>Note:</strong> This pricelist is used for export only - its price goes to Shopify as the Price,
                        and the regular Odoo price becomes the <strong>Compare at Price</strong>.<br />
                        On import, if <strong>Compare at Price</strong> is set in Shopify, it will override the regular price in Odoo.
                        Shopify's <strong>Price</strong> or <strong>Compare at Price</strong> are never imported into this pricelist.
                    </span>
                </xpath>

                <xpath expr="//group[@name='inventory_location_mapping']/field[@name='location_line_ids']/." position="before">
                    <field name="invalid_location_mapping" invisible="1"/> <!-- Required because it is used in the invisible condition below -->
                    <div class="alert alert-warning mb-1" role="alert" invisible="not invalid_location_mapping" colspan="2">
                        <h4 style="color: inherit"><i class="fa fa-gear" title="Invalid Location Mapping"/> Invalid Location Mapping</h4>
                        All e-commerce locations must be mapped to unique Odoo warehouses. Duplicate warehouse mappings are not allowed.
                        Please ensure that each e-commerce location is associated with a distinct Odoo warehouse to avoid configuration issue.
                    </div>
                </xpath>

                <group name="barcode_ecomm_fields" position="after">
                    <group name="shopify_advanced_sync_settings" string="Advanced Synchronization Settings" invisible="not is_integration_shopify">
                        <field name="translations_sync" widget="boolean_toggle"/>
                    </group>
                </group>

                <!-- Webhook Security (Advanced) section - only visible in debug mode for Shopify -->
                <xpath expr="//page[@name='webhooks_defaults']/group[@name='webhooks_logging']" position="after">
                    <group name="webhook_security_advanced" string="Webhook Security (Advanced)" groups="base.group_no_one" invisible="not is_integration_shopify">
                        <div class="alert alert-info" role="alert" colspan="2">
                            <p class="mb-2">
                                <strong>About Webhook HMAC Validation</strong>
                            </p>
                            <p class="mb-2">
                                Shopify signs all webhook requests using HMAC-SHA256 with your app's Client Secret.
                                This validation ensures webhooks are genuinely from Shopify and haven't been tampered with.
                            </p>
                            <p class="mb-2">
                                <strong>Important:</strong> Shopify always signs webhooks using the
                                <em>oldest unrevoked Client Secret</em>. If you have multiple active secrets,
                                webhooks will be signed with the oldest one until you explicitly revoke it.
                            </p>
                            <p class="mb-2">
                                After revoking an old secret, it may take <strong>up to 1 hour</strong> for
                                Shopify to start signing webhooks with the new secret. During this transition
                                period, webhook validation may fail if your connector only has the new secret
                                configured.
                            </p>
                            <p class="mb-0">
                                <strong>Recommendation:</strong> If you experience webhook validation failures after
                                rotating your secret, you may temporarily disable validation below. Re-enable it after
                                1 hour when Shopify completes the transition.
                                <br/>
                                <a href="https://shopify.dev/docs/apps/build/webhooks/subscribe/https#verify-a-webhook"
                                   target="_blank">Shopify Webhook Verification Documentation</a>
                                <br/>
                                <a href="https://shopify.dev/docs/apps/build/authentication-authorization/client-secrets/rotate-revoke-client-credentials"
                                   target="_blank">Shopify Secret Rotation Documentation</a>
                            </p>
                        </div>
                        <field name="enable_webhook_hmac_validation" widget="boolean_toggle"/>
                    </group>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
