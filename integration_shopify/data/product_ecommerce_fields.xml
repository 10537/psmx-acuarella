        <record id="shopify_ecommerce_field_variant_weight" model="product.ecommerce.field">
            <field name="name">Product Variant Weight</field>
            <field name="technical_name">weight</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_product"/>
            <field name="odoo_field_id" ref="product.field_product_product__weight"/>
            <field name="auto_create_mapping" eval="True"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="True"/>
            <field name="default_for_import" eval="True"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('product.field_product_product__weight'),))]"/>
            <field name="export_field_type">float</field>
            <field name="import_script">
_, variant_data = external_data
product_variant = integration.adapter.gql.ProductVariant.set(**variant_data)
inventory_item = product_variant.inventory_item

if not inventory_item:
    value = {}
else:
    value_ = env['uom.uom']._convert_external_weight_uom(
        inventory_item.weight,
        inventory_item.weight_unit,
    )

    odoo_name = field.get_odoo_field_name()

    value = {
        odoo_name: value_,
    }

            </field>
            <field name="export_script">
value_ = variant.weight

if not value_:
    value = {}
else:
    WeightUnit = integration.adapter.gql.WeightUnit

    api_name = field.get_api_field_name()

    value = {
        'inventoryItem': {
            'measurement': {
                api_name: {
                    'value': value_,
                    'unit': WeightUnit.convert_weight_unit_out(variant.weight_uom_name),
                }
            }
        }
    }
            </field>
        </record>

        <record id="shopify_ecommerce_field_variant_default_code" model="product.ecommerce.field">
            <field name="name">Product Variant SKU</field>
            <field name="technical_name">sku</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_product"/>
            <field name="odoo_field_id" ref="product.field_product_product__default_code"/>
            <field name="auto_create_mapping" eval="True"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="True"/>
            <field name="default_for_import" eval="True"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('product.field_product_product__default_code'),))]"/>
            <field name="export_field_type">string</field>
            <field name="import_script"/>
            <field name="export_script">
value_ = field \
    .with_context(integration_force_product_export=FORCE_PRODUCT_EXPORT) \
    ._build_export_field_dict(integration.id, variant.id)

value = {
    'inventoryItem': value_,
}
            </field>
        </record>

        <record id="shopify_ecommerce_field_variant_price" model="product.ecommerce.field">
            <field name="name">Product Variant Price</field>
            <field name="technical_name">price</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_product"/>
            <field name="odoo_field_id" ref="integration.field_product_product__variant_extra_price"/>
            <field name="auto_create_mapping" eval="True"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="True"/>
            <field name="default_for_import" eval="True"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('integration.field_product_product__variant_extra_price'), ref('product.field_product_product__lst_price'),))]"/>
            <field name="export_field_type">string</field>
            <field name="import_script">
# TODO price_including_taxes

if integration.integration_pricelist_id and not FIRST_TIME_IMPORT:
    value = {}
else:
    _, variant_data = external_data
    v = integration.adapter.gql.ProductVariant.set(**variant_data)
    has_pricelist_ = bool(integration.integration_sale_pricelist_id)

    price = v.get_price(has_integration_pricelist=has_pricelist_)

    odoo_name = field.get_odoo_field_name()
    value_ = price - (variant.lst_price - variant.variant_extra_price)

    value = {
        odoo_name: value_,
    }
            </field>
            <field name="export_script">
pricelist = integration.integration_pricelist_id

if pricelist:
    sale_price = pricelist._get_product_price(variant, 0)
    compare_at_price = variant.lst_price

    if sale_price == compare_at_price:
        compare_at_price = 0
else:
    sale_price = variant.lst_price
    compare_at_price = 0

sale_price_value = variant.get_price_by_send_tax_incl(integration.id, sale_price)
compare_at_price_value = variant.get_price_by_send_tax_incl(integration.id, compare_at_price)

api_name = field.get_api_field_name()

value = {
    api_name: sale_price_value,
    'compareAtPrice': compare_at_price_value,
}
            </field>
        </record>

        <record id="shopify_ecommerce_field_variant_cost_price" model="product.ecommerce.field">
            <field name="name">Product Variant Cost Price</field>
            <field name="technical_name">cost</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_product"/>
            <field name="odoo_field_id" ref="product.field_product_product__standard_price"/>
            <field name="auto_create_mapping" eval="True"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="True"/>
            <field name="default_for_import" eval="True"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('product.field_product_product__standard_price'),))]"/>
            <field name="export_field_type">string</field>
            <field name="import_script">
_, variant_data = external_data
product_variant = integration.adapter.gql.ProductVariant.set(**variant_data)
inventory_item = product_variant.inventory_item

if inventory_item:
    value_ = inventory_item.cost

    odoo_name = field.get_odoo_field_name()

    value = {
        odoo_name: value_,
    }
else:
    value = {}
            </field>
            <field name="export_script">
value_ = variant._get_integration_cost_price(integration.id)

api_name = field.get_api_field_name()

value = {
    'inventoryItem': {
        api_name: value_,
    }
}
            </field>
        </record>

        <record id="shopify_ecommerce_field_variant_taxable_flag" model="product.ecommerce.field">
            <field name="name">Product Variant Taxable Flag</field>
            <field name="technical_name">taxable</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_product"/>
            <field name="odoo_field_id" ref="account.field_product_product__taxes_id"/>
            <field name="auto_create_mapping" eval="True"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="True"/>
            <field name="default_for_import" eval="True"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('account.field_product_product__taxes_id'),))]"/>
            <field name="export_field_type">boolean</field>
            <field name="import_script">
_, variant_data = external_data
product_variant = integration.adapter.gql.ProductVariant.set(**variant_data)

taxable = product_variant.taxable

if taxable:
    value = {}
else:
    odoo_name = field.get_odoo_field_name()

    value = {
        odoo_name: False,
    }
            </field>
            <field name="export_script">
api_name = field.get_api_field_name()

value = {
    api_name: bool(template.taxes_id),
}
            </field>
        </record>

