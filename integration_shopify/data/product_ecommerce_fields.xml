        <record id="shopify_ecommerce_field_status" model="product.ecommerce.field">
            <field name="name">Product Status</field>
            <field name="technical_name">status</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_template"/>
            <field name="auto_create_mapping" eval="True"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="True"/>
            <field name="default_for_import" eval="True"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('product.field_product_template__active'), ref('product.field_product_template__sale_ok'), ref('stock.field_product_template__is_storable'),))]"/>
            <field name="export_field_type">string</field>
            <field name="import_script">
template_data, _ = external_data
product = integration.adapter.gql.Product.set(**template_data)

value = {
    'sale_ok': product.is_active,
    'active': not product.is_archived,
}

if FIRST_TIME_IMPORT:
    value.update(
        active=True,
        is_storable=True,
    )
            </field>
            <field name="export_script">
ProductStatus = integration.adapter.gql.ProductStatus

send_inactive_product = integration.send_inactive_product and not EXTERNAL_CODE

if send_inactive_product or not template.sale_ok:
    value_ = ProductStatus.draft.value
else:
    value_ = ProductStatus.from_odoo(template.active)

api_name = field.get_api_field_name()

value = {
    api_name: value_,
}
            </field>
        </record>

        <record id="shopify_ecommerce_field_collections" model="product.ecommerce.field">
            <field name="name">Product Collections</field>
            <field name="technical_name">collections</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_template"/>
            <field name="odoo_field_id" ref="integration.field_product_template__public_categ_ids"/>
            <field name="auto_create_mapping" eval="True"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="False"/>
            <field name="default_for_import" eval="False"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('integration.field_product_template__public_categ_ids'),))]"/>
            <field name="export_field_type">integer</field>
            <field name="import_script">
template_data, _ = external_data
product = integration.adapter.gql.Product.set(**template_data)
collections = product.collections

ProductPublicCategory = env['product.public.category']
value_ = ProductPublicCategory.browse()

for collection in collections:
    value_ |= ProductPublicCategory \
        .from_external(integration, collection.id_str)

odoo_name = field.get_odoo_field_name()

value = {
    odoo_name: [(6, 0, value_.ids)],
}
            </field>
            <field name="export_script">
collection_ids = template.get_categories(integration.id)

if not EXTERNAL_CODE:
    key = 'collections'
else:
    key = 'collectionsToJoin'

Collection = integration.adapter.gql.Collection

value = {
    key: [Collection.create_gid(x) for x in collection_ids],
}
            </field>
        </record>

        <record id="shopify_ecommerce_product_tags" model="product.ecommerce.field">
            <field name="name">Product Tags</field>
            <field name="technical_name">tags</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_template"/>
            <field name="odoo_field_id" ref="integration.field_product_template__external_tag_group_ids"/>
            <field name="auto_create_mapping" eval="False"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="True"/>
            <field name="default_for_import" eval="True"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('integration.field_product_template__external_tag_group_ids'),))]"/>
            <field name="export_field_type">string</field>
            <field name="import_script">
template_data, _ = external_data
product = integration.adapter.gql.Product.set(**template_data)

tag_ids = [
    env['external.integration.tag']._get_or_create_external_tag(name, 'product', integration_id=integration.id).id
    for name in product.tags
]

odoo_name = field.get_odoo_field_name()

if template:
    group = template.get_or_create_tag_group(integration.id)
    commands = [(1, group.id, {'tag_ids': [(6, 0, tag_ids)]})]
else:
    commands = [(0, 0, {'integration_id': integration.id, 'tag_ids': [(6, 0, tag_ids)]})]

value = {odoo_name: commands}
            </field>
            <field name="export_script">
api_name = field.get_api_field_name()

tag_names = template.external_tag_group_ids.filtered(
    lambda g: g.integration_id.id == integration.id
).mapped('tag_ids').mapped('name')

value = {
    api_name: tag_names,
}
            </field>
        </record>

        <record id="shopify_ecommerce_field_template_price" model="product.ecommerce.field">
            <field name="name">Product Price</field>
            <field name="technical_name">price</field>
            <field name="type_api">shopify</field>
            <field name="odoo_model_id" ref="product.model_product_template"/>
            <field name="odoo_field_id" ref="product.field_product_template__list_price"/>
            <field name="auto_create_mapping" eval="True"/>
            <field name="is_default" eval="True"/>
            <field name="default_for_update" eval="True"/>
            <field name="default_for_import" eval="True"/>
            <field name="trackable_fields_ids" eval="[(6, 0, (ref('product.field_product_template__list_price'),))]"/>
            <field name="import_script">
# TODO price_including_taxes

if integration.integration_pricelist_id and not FIRST_TIME_IMPORT:
    value = {}
else:
    prices = []
    template_data, _ = external_data

    for variant_data in template_data['variants']:
        v = integration.adapter.gql.ProductVariant.set(**variant_data)
        has_pricelist_ = bool(integration.integration_sale_pricelist_id)

        price = v.get_price(has_integration_pricelist=has_pricelist_)
        prices.append(price)

    odoo_name = field.get_odoo_field_name()

    value = {
        odoo_name: min(prices),
    }
            </field>
            <field name="export_script">
value = {}
            </field>
        </record>

