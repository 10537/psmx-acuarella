<odoo>
  <data>

        <record id="melonn_delivery_carrier" model="ir.ui.view">
            <field name="name">delivery.carrier.melonn</field>
            <field name="model">delivery.carrier</field>
            <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
            <field name="arch" type="xml">
                <xpath expr="/form/sheet/notebook" position="inside">
                    <page string="Melonn">
                        <group>
                            <field name="token"/>
                            <field name="url_product_melonn"/>
                            <field name="url_sale_order_melonn"/>
                        </group>
                    </page>
                    <page string="Generación">
                        <group>
                            <field name="wsg_test"/>
                        </group>
                        <group string="Producción">
                            <field name="wsg_production_url"/>
                            <field name="wsg_production_usuario"/>
                            <field name="wsg_production_password" password="1"/>
                            <field name="wsg_production_cod_regional"/>
                            <field name="wsg_production_cod_oficina"/>
                            <field name="wsg_production_cod_cuenta"/>
                            <field name="wsg_production_cod_cuenta_recaudo"/>
                        </group>
                        <group string="Pruebas">
                            <field name="wsg_test_url"/>
                            <field name="wsg_test_usuario"/>
                            <field name="wsg_test_password" password="1"/>
                            <field name="wsg_test_cod_regional"/>
                            <field name="wsg_test_cod_oficina"/>
                            <field name="wsg_test_cod_cuenta"/>
                            <field name="wsg_test_cod_cuenta_recaudo"/>
                        </group>
                    </page>
                    <page string="Configuración de API Coordinadora">
                        <group>
                            <field name="coordinadora_use_api"/>
                        </group>
                        <group invisible="not coordinadora_use_api">
                            <group string="Credenciales">
                                <field name="coordinadora_client_id" required="coordinadora_use_api"/>
                                <field name="coordinadora_user" required="coordinadora_use_api"/>
                                <field name="coordinadora_password" password="1" required="coordinadora_use_api"/>
                                <field name="coordinadora_apikey" required="coordinadora_use_api"/>
                                <field name="coordinadora_tracking_password" password="1" required="coordinadora_use_api"/>
                                <field name="coordinadora_nit" required="coordinadora_use_api"/>
                                <field name="coordinadora_div" required="coordinadora_use_api"/>
                            </group>
                            <group string="Entorno y URLs">
                                <field name="coordinadora_environment" widget="radio"/>
                                <field name="coordinadora_ws_guias_test" invisible="coordinadora_environment != 'test'" required="coordinadora_environment == 'test' and coordinadora_use_api"/>
                                <field name="coordinadora_ws_seguimiento_test" invisible="coordinadora_environment != 'test'" required="coordinadora_environment == 'test' and coordinadora_use_api"/>
                                <field name="coordinadora_ws_guias_prod" invisible="coordinadora_environment != 'production'" required="coordinadora_environment == 'production' and coordinadora_use_api"/>
                                <field name="coordinadora_ws_seguimiento_prod" invisible="coordinadora_environment != 'production'" required="coordinadora_environment == 'production' and coordinadora_use_api"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>