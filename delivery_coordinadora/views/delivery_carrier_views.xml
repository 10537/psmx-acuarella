<odoo>
    <data>
        <record id="view_delivery_carrier_form_coordinadora" model="ir.ui.view">
            <field name="name">delivery.carrier.coordinadora.form</field>
            <field name="model">delivery.carrier</field>
            <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='destination']" position="before">
                    <page string="Coordinadora Configuration" invisible="delivery_type != 'coordinadora'">
                        <group>
                            <field name="coordinadora_use_api"/>
                        </group>
                        <group invisible="not coordinadora_use_api">
                            <group string="Credentials">
                                <field name="coordinadora_client_id" required="delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_user" required="delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_password" password="1" required="delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_apikey" required="delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_tracking_password" password="1" required="delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_nit" required="delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_div" required="delivery_type == 'coordinadora' and coordinadora_use_api"/>
                            </group>
                            <group string="Environment &amp; URLs">
                                <field name="coordinadora_environment" widget="radio"/>
                                <field name="coordinadora_ws_guias_test" invisible="coordinadora_environment != 'test'" required="coordinadora_environment == 'test' and delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_ws_seguimiento_test" invisible="coordinadora_environment != 'test'" required="coordinadora_environment == 'test' and delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_ws_guias_prod" invisible="coordinadora_environment != 'production'" required="coordinadora_environment == 'production' and delivery_type == 'coordinadora' and coordinadora_use_api"/>
                                <field name="coordinadora_ws_seguimiento_prod" invisible="coordinadora_environment != 'production'" required="coordinadora_environment == 'production' and delivery_type == 'coordinadora' and coordinadora_use_api"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
        <record id="view_order_form_coordinadora" model="ir.ui.view">
            <field name="name">sale.order.coordinadora.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='other_information']" position="inside">
                    <group string="Coordinadora Shipping" invisible="not carrier_delivery_ref">
                        <field name="carrier_delivery_ref" readonly="1"/>
                        <field name="carrier_delivery_url" readonly="1" widget="url"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
