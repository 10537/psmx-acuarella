<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_integration_form_inherit_ssot" model="ir.ui.view">
        <field name="name">sale.integration.form.inherit.ssot</field>
        <field name="model">sale.integration</field>
        <field name="inherit_id" ref="integration.view_sale_integration_form"/>
        <field name="arch" type="xml">
            <!-- Add the enforce_ssot field to the settings. We will put it inside the notebook page or header -->
            <xpath expr="//header" position="after">
                <widget name="web_ribbon" title="SSOT Enforced" bg_color="bg-success" invisible="not enforce_ssot or not is_integration_shopify"/>
            </xpath>
            <xpath expr="//group[@name='integration_settings']" position="inside">
                <field name="enforce_ssot" invisible="not is_integration_shopify" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>
