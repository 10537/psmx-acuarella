<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="integration.ProductEcommerceFieldListView" t-inherit="web.ListRenderer" t-inherit-mode="primary" owl="1">
        <xpath expr="//div[@class='o_list_renderer o_renderer table-responsive']" position="before">
            <div class="o_onboarding_container collapse show">
                <div class="o_onboarding_main position-relative overflow-hidden o_onboarding_violet py-3"
                     style="background: linear-gradient(135deg, #A04A25 0%, #9A033F 25%, #5F7A2A 75%, #3A1F5A 100%);">
                    <div class="o_onboarding_steps d-flex justify-content-center align-items-center">
                        <div class="container-fluid px-4">
                            <div class="card shadow-sm border-0 bg-white">
                                <div class="card-body p-3">
                                    <div class="row align-items-start">
                                        <div class="col-md-5 mb-3 mb-md-0">
                                            <h4 class="card-title mb-2 text-dark">
                                                <i class="fa fa-info-circle text-primary me-2" title="Information"></i>
                                                What is this?
                                            </h4>
                                            <p class="mb-0 text-dark">
                                                Field definitions are templates that describe how a field should be synchronized (which Odoo field maps to which e-commerce field). Each definition can be used by multiple stores.
                                            </p>
                                        </div>

                                        <div class="col-md-4 mb-3 mb-md-0">
                                            <h5 class="mb-2 text-dark">
                                                <i class="fa fa-tasks text-success me-2" title="Tasks"></i>
                                                Common tasks:
                                            </h5>
                                            <ul class="list-unstyled mb-0">
                                                <li class="mb-1 text-dark">
                                                    <i class="fa fa-check-circle text-primary me-2" title="Task"></i>
                                                    Create a new field mapping (e.g., for Shopify metafields)
                                                </li>
                                                <li class="mb-1 text-dark">
                                                    <i class="fa fa-check-circle text-primary me-2" title="Task"></i>
                                                    Configure field transformation scripts (advanced)
                                                </li>
                                            </ul>
                                        </div>

                                        <div class="col-md-3">
                                            <div class="alert alert-info mb-0 py-2" role="alert">
                                                <i class="fa fa-lightbulb-o me-1" title="Tip"></i>
                                                <small><strong>Tip:</strong> After creating a definition, go to <strong>Field Synchronization</strong> to enable it for your store(s).</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </t>

</templates>
