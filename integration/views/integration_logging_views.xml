<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="integration_logging_form_view">
        <field name="model">integration.logging</field>
        <field name="arch" type="xml">
            <form string="Log" create="0">
            <sheet>
                <group name="creation_details" string="Creation details">
                    <field name="create_date" />
                </group>
                <group name="log_details" string="Logging details">
                    <field name="integration_id" readonly="1" />
                    <field name="event_type" readonly="1" />
                    <field name="event_name" readonly="1" />
                    <field name="message" readonly="1" />
                </group>
            </sheet>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="integration_logging_list_view">
        <field name="model">integration.logging</field>
        <field name="arch" type="xml">
            <list string="Logs">
                <field name="integration_id"/>
                <field name="event_type"/>
                <field name="event_name"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="integration_logging_search_view">
        <field name="model">integration.logging</field>
        <field name="arch" type="xml">
            <search string="Logs">
                <field name="event_type" />
                <field name="event_name" />
                <field name="message" />
                <group expand="0" string="Group By">
                    <filter string="E-Commerce Store" name="group_by_integration_id" domain="[]" context="{'group_by': 'integration_id'}" />
                    <filter string="Event Type" name="group_by_event_type" domain="[]" context="{'group_by': 'event_type'}" />
                    <filter string="Event Name" name="group_by_event_name" domain="[]" context="{'group_by': 'event_name'}" />
                    <filter string="Creation Date" name="group_by_month" domain="[]" context="{'group_by': 'create_date'}" />
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="integration_logging_action">
        <field name="name">Logging</field>
        <field name="res_model">integration.logging</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
