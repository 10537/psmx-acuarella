<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="integration_product_template_external_view_tree" model="ir.ui.view">
            <field name="name">integration.product.template.external.view.list</field>
            <field name="model">integration.product.template.external</field>
            <field name="arch" type="xml">
                <list editable="bottom" create="0">
                    <field name="id" groups="base.group_no_one"/>
                    <field name="integration_id"/>
                    <field name="code" string="External ID"/>
                    <field name="name" string="Product Name"/>
                    <field name="external_reference" string="SKU / Reference"/>
                    <field name="external_barcode" string="Barcode"/>
                    <field name="timestamp_export_datetime" string="Last Export" optional="hide"/>
                    <field name="external_product_variant_ids" string="Variants" widget="many2many_tags" optional="hide"/>

                    <!-- Action buttons -->
                    <button name="action_open_import_wizard"
                            string="Manage"
                            title="Open wizard to import this product or link it to existing Odoo product"
                            icon="fa-gear"
                            type="object"
                            class="btn-outline-primary"/>
                    <button name="action_open_mapping"
                            string="Open Mapping"
                            title="Open the mapping record to see linked Odoo product"
                            icon="fa-link"
                            type="object"
                            class="btn-outline-secondary"/>
                    <button name="action_open_external_product"
                            string="View in Shop"
                            title="Open this product in e-commerce store admin panel"
                            icon="fa-external-link"
                            type="object"
                            class="btn-outline-secondary"
                            invisible="not code"/>
                </list>
            </field>
        </record>

        <record id="integration_product_template_external_search" model="ir.ui.view">
            <field name="model">integration.product.template.external</field>
            <field name="name">Search Integration Templates</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Product Name"/>
                    <field name="code" string="External ID"/>
                    <field name="external_reference" string="SKU / Reference"/>
                    <field name="external_barcode" string="Barcode"/>
                    <field name="external_product_variant_ids" string="Variants"/>
                    <field name="integration_id" string="E-Commerce Store"/>
                    <group expand="0" string="Group By">
                        <filter string="E-Commerce Store" name="group_by_integration_id" context="{'group_by': 'integration_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="integration_product_template_external_action" model="ir.actions.act_window">
            <field name="name">External Products</field>
            <field name="path">eci-external-products</field>
            <field name="res_model">integration.product.template.external</field>
            <field name="view_mode">list</field>
        </record>

        <record id="integration_product_template_external_action_run_import_products" model="ir.actions.server">
            <field name="name">Create in Odoo</field>
            <field name="model_id" ref="integration.model_integration_product_template_external"/>
            <field name="binding_model_id" ref="integration.model_integration_product_template_external"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">action = records.run_import_products()</field>
        </record>

        <record id="integration_product_template_external_action_try_map_products" model="ir.actions.server">
            <field name="name">Auto-Link</field>
            <field name="model_id" ref="integration.model_integration_product_template_external"/>
            <field name="binding_model_id" ref="integration.model_integration_product_template_external"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">[x.integration_id.import_external_product(x.code) for x in records]</field>
        </record>

    </data>
</odoo>
