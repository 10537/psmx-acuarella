<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="model_product_template_action_force_export_to_external" model="ir.actions.server">
        <field name="name">Export to Stores</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">form,list</field>
        <field name="state">code</field>
        <field name="code">action = records.with_context(manual_trigger=True).trigger_export(export_images=True)</field>
    </record>

    <record id="model_product_template_action_force_export_inventory" model="ir.actions.server">
        <field name="name">Export Stock to Stores</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">form,list</field>
        <field name="state">code</field>
        <field name="code">action = records.product_variant_ids.action_force_export_inventory()</field>
    </record>

    <record id="product_template_change_external_integration" model="ir.actions.server">
        <field name="name">Manage Store Connections</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">form,list</field>
        <field name="groups_id" eval="[(6, 0, (ref('integration.group_integration_manager'),))]"/>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.change_external_integration_template()
        </field>
    </record>

    <record id="model_product_template_action_refresh_product_info" model="ir.actions.server">
        <field name="name">Refresh from Store</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">form,list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_run_refresh_product_info_from_external()</field>
    </record>

    <record id="product_template_action_open_job_logs" model="ir.actions.server">
        <field name="name">View Sync Logs</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="groups_id" eval="[(4, ref('integration.group_integration_manager'))]"/>
        <field name="code">action = records.open_job_logs()</field>
    </record>

    <record model="ir.ui.view" id="product_template_search_view">
        <field name="name">product.template</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <filter string="With Bill of Materials" name="with_bom" domain="[('bom_ids', '!=', False)]"/>
                <separator/>
                <filter string="E-Commerce Store(s) set (on all variants)" name="all_integrations_set" domain="[('integration_ids', '!=', False)]"/>
                <filter string="No E-Commerce Store(s) set (on any variant)" name="no_integrations_set" domain="[('integration_ids', '=', False)]"/>
                <filter string="E-Commerce Store(s) set (on some variants)" name="partial_integrations_set" domain="[('integration_ids', '=', -1)]"/>
                <separator/>
                <filter string="Do not sync with E-Commerce Stores" name="exclude_from_synchronization" domain="[('exclude_from_synchronization', '=', True)]"/>
                <filter string="Do not sync stock with E-Commerce Stores" name="exclude_from_synchronization_stock" domain="[('exclude_from_synchronization_stock', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="product_template_form_view">
        <field name="name">product.template</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <group name="upsell" position="attributes">
                <attribute name="invisible">0</attribute>
            </group>

            <xpath expr="//page[@name='sales']" position="after">
                <page name="shop" string="E-Commerce Integration">
                    <field name="bom_ids" invisible="1" groups="mrp.group_mrp_user"/> <!-- Required because it is used in the invisible condition below -->

                    <!-- BOM Warning Alert -->
                    <div class="row mx-0" colspan="2" invisible="product_variant_count &lt; 2 or not bom_ids" groups="mrp.group_mrp_user">
                        <div class="alert alert-warning" role="alert">
                            <h4><i class="fa fa-warning" title="Attention"/> Attention</h4>
                            <p class="mb-0">
                                This product contains multiple variants and has an associated Bill of Materials (BOM).
                                It will be exported to the e-commerce system as a configurable product without displaying individual components.
                            </p>
                        </div>
                    </div>

                    <!-- Store Configuration Section -->
                    <group name="store_configuration">
                        <!-- Information Panel -->
                        <group name="integration_info" string="How E-Commerce Integration Works">
                            <div class="alert alert-info" role="alert" colspan="2">
                                <p class="mb-2">
                                    <i class="fa fa-info-circle" title="Information"/>
                                    This tab allows you to configure how your product appears and behaves in your e-commerce stores
                                    (Shopify, WooCommerce, PrestaShop, Magento2, etc.).
                                </p>
                                <p class="mb-2">
                                    <strong>Quick Setup:</strong>
                                </p>
                                <ul class="mb-0">
                                    <li>Select which stores to sync with</li>
                                    <li>Customize product information for stores</li>
                                    <li>Set up categories and features</li>
                                    <li>Add product images and media</li>
                                </ul>
                            </div>
                        </group>

                        <!-- Store Selection -->
                        <group name="integrations" string="E-Commerce Stores">
                            <div colspan="2">
                                <div class="alert alert-info" role="alert" invisible="not id or product_variant_count &lt;= 1 or is_product_variant">
                                    <i class="fa fa-info-circle" title="Information"/>
                                    This product has multiple variants. Store synchronization must be configured at the Product Variant level.
                                </div>
                            </div>
                            <group colspan="2" name="integrations_field" invisible="product_variant_count &gt; 1 and not is_product_variant">
                                <field name="integration_ids" widget="many2many_checkboxes"/>
                            </group>
                            <group colspan="2" name="synchronization_settings">
                                <field name="exclude_from_synchronization" help="Check to prevent this product from being exported to any e-commerce store"/>
                                <field name="exclude_from_synchronization_stock" help="Check to prevent stock levels from being synchronized with e-commerce stores"/>
                            </group>
                        </group>
                    </group>

                    <!-- Product Information Section -->
                    <group name="product_information" string="Product Information">
                        <div colspan="2">
                            <div class="alert alert-info" role="alert">
                                <p class="mb-0">
                                    <i class="fa fa-info-circle" title="Information"/>
                                    Customize how this product appears in your e-commerce stores.
                                    These fields override the standard product information when syncing to stores.
                                </p>
                            </div>
                        </div>
                        <group colspan="2">
                            <field name="website_product_name" help="Custom product name for e-commerce stores. If empty, the standard product name will be used."/>
                            <field name="website_short_description" help="Brief description shown in product listings and search results"/>
                            <field name="website_description" help="Detailed product description shown on the product page"/>
                        </group>
                    </group>

                    <!-- Categories and Features Section -->
                    <group name="categorization">
                        <group string="Categories">
                            <field name="default_public_categ_id" domain="[('id', 'in', public_filter_categ_ids)]" options="{'no_create': True, 'no_edit': True}" help="Primary category for this product in e-commerce stores"/>
                            <field name="public_categ_ids" widget="many2many">
                                <list string="Additional Categories">
                                    <field name="display_name" nolabel="1"/>
                                </list>
                            </field>
                            <field name="public_filter_categ_ids" widget="many2many_tags" invisible="1"/>  <!-- Required because it is used in the fields domains in the model -->
                        </group>

                        <group string="Product Features">
                            <field name="feature_line_ids" widget="one2many" nolabel="1" colspan="2">
                                <list editable="bottom" string="Product Features">
                                    <field name="feature_id" help="Select a feature (e.g., Color, Size, Material)"/>
                                    <field name="feature_value_id" context="{'default_feature_id': feature_id}" help="Select the specific value for this feature"/>
                                </list>
                            </field>
                        </group>

                    </group>

                    <!-- SEO Section -->
                    <group string="SEO Settings" colspan="2">
                        <div colspan="2">
                            <div class="alert alert-info" role="alert">
                                <p class="mb-0">
                                    <i class="fa fa-info-circle" title="Information"/>
                                    Configure search engine optimization settings for your product.
                                    <strong>Important:</strong> Field mappings for these SEO fields must be enabled in your integration settings
                                    for this information to be synchronized to your e-commerce stores.
                                </p>
                            </div>
                        </div>
                        <field name="website_seo_metatitle" help="Meta title for search engines (recommended: 50-60 characters)"/>
                        <field name="website_seo_description" help="Meta description for search engines (recommended: 150-160 characters)"/>

                        <field name="external_tag_group_ids" colspan="2" context="{'default_product_tmpl_id': id}">
                            <list editable="bottom" string="Tags by Store" create="1">
                                <field name="integration_type_api" column_invisible="1"/>
                                <field name="integration_id" options="{'no_create': True}" domain="[('type_api', 'in', ('shopify', 'prestashop'))]"/>
                                <field name="tag_ids"
                                       widget="many2many_tags"
                                       readonly="not integration_id"
                                       context="{'default_ttype': 'product', 'default_integration_id': integration_id, 'default_external_language_id': external_language_id}"
                                />
                            </list>
                        </field>
                    </group>

                    <!-- Store Specific Settings Section -->
                    <group name="store_specific_settings">
                        <!-- Content will be added here dynamically based on the selected stores -->
                    </group>

                    <!-- Media Section -->
                    <group name="media_section" string="Extra Product Images">
                        <div colspan="2">
                            <div class="alert alert-info" role="alert">
                                <p class="mb-0">
                                    <i class="fa fa-info-circle" title="Information"/>
                                    Add additional images for your product.
                                    These will be synchronized to your e-commerce stores to showcase your product.
                                </p>
                            </div>
                        </div>

                        <group name="product_template_images" colspan="2">
                            <field name="product_template_image_ids"
                                   colspan="2"
                                   class="o_website_sale_image_list"
                                   context="{'default_name': name}"
                                   mode="kanban"
                                   add-label="Add Image"
                                   nolabel="1"
                                   widget="x2_many_media_viewer"
                            />

                            <button type="object"
                                    name="export_images_to_integration"
                                    context="{'integration_erase_mappings': True}"
                                    string="Export Images Only"
                                    groups="base.group_no_one"
                                    colspan="2"
                                    help="Export only the product images to e-commerce stores without updating other product data"
                            />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="product_template_only_form_view_inherit" model="ir.ui.view">
        <field name="name">product.template.product.form.inherit</field>
        <field name="model">product.template</field>
        <field name="priority">99</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <button name="%(product.product_variant_action)d" position="after">
                <button name="%(product.product_variant_action)d"
                    type="action"
                    icon="fa-sitemap"
                    class="oe_stat_button"
                    groups="product.group_product_variant"
                    invisible="product_variant_count &gt;= 2">
                    <field string="Variants" name="product_variant_count" widget="statinfo"/>
                </button>
            </button>
            <div name="button_box" position="inside">
                <button class="oe_stat_button"
                    name="action_integration_mappings"
                    type="object"
                    icon="fa-list-ul"
                    help="E-Commerce Store Mappings"
                    invisible="not mapping_count">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="mapping_count" widget="statinfo" nolabel="1" class="mr4"/>
                        </span>
                        <span class="o_stat_text">Store Mappings</span>
                    </div>
                </button>
            </div>
            <xpath expr="//page[@name='variants']/field[@name='attribute_line_ids']" position="before">
                <field name="is_used_dynamic_attributes" invisible="1"/> <!-- Required because it is used in the invisible condition below -->
                <div class="alert alert-warning" role="alert" invisible="not is_used_dynamic_attributes">
                    <p>
                        There are "Dynamic" attributes added to table below. That mean product variants will not be generated automatically for them. Click this button to generate all missing variants
                    </p>
                    <hr/>
                    <button name="generate_variants" type="object" string="Generate variants" invisible="not is_used_dynamic_attributes"/>
                </div>
            </xpath>
            <xpath expr="//page[@name='variants']/field/list/field[@name='value_ids']" position="replace">
                <field name="value_ids" style="width: 100%" widget="many2many_tags" options="{'no_create_edit': True, 'color_field': 'color'}" context="{'default_attribute_id': attribute_id, 'show_attribute': False}"/>
                <field name="exclude_from_synchronization"/>
                <field name="is_dynamic_creation_mode"/>
            </xpath>
        </field>
    </record>

</odoo>
