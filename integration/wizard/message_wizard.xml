<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="integration_message_wizard_form" model="ir.ui.view">
        <field name="name">integration.message.wizard.form</field>
        <field name="model">message.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="message" readonly="1"/>
                <footer>
                    <button name="action_close" string="Close" type="object" default_focus="1" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="integration_message_wizard_html_form" model="ir.ui.view">
        <field name="name">integration.message.wizard.html.form</field>
        <field name="model">message.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="export_html" readonly="1"/>
                <footer>
                    <button name="action_close" string="Close" type="object" default_focus="1" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="integration_message_wizard_json_form" model="ir.ui.view">
        <field name="name">integration.message.wizard.json.form</field>
        <field name="model">message.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="export_json" widget="code" options="{'mode': 'python'}" readonly="1"/>
                <footer>
                    <button name="action_close" string="Close" type="object" default_focus="1" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="integration_message_wizard_validate_template_form" model="ir.ui.view">
        <field name="name">integration.message.wizard.validate.template.form</field>
        <field name="model">message.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="message" readonly="1" invisible="1"/> <!-- Required because it is used in the fields domains in the model -->
                <field name="export_html" readonly="1"/>
                <footer>
                    <button name="action_close" string="Close" type="object" default_focus="1" class="oe_highlight"/>
                    <button name="download_pdf" string="PDF" type="object"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="integration_message_wizard_form_mapping_product" model="ir.ui.view">
        <field name="name">integration.message.wizard.form.mapping.product</field>
        <field name="model">message.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="message" readonly="1" invisible="1"/> <!-- Required because it is used in the fields domains in the model -->
                <field name="export_html" readonly="1"/>
                <footer>
                    <button name="action_close" string="Close" type="object" default_focus="0" class="oe_highlight"/>
                    <button name="open_mapping" string="Open" type="object" default_focus="1" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
