<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wms_sorter_api_log_view_tree" model="ir.ui.view">
        <field name="name">wms.sorter.api.log.view.tree</field>
        <field name="model">wms.sorter.api.log</field>
        <field name="arch" type="xml">
            <list string="API Logs" decoration-danger="state == 'error'" decoration-success="state == 'success'" create="false" edit="false">
                <field name="create_date"/>
                <field name="name"/>
                <field name="method"/>
                <field name="ip_address"/>
                <field name="status_code"/>
                <field name="state" widget="badge" decoration-danger="state == 'error'" decoration-success="state == 'success'"/>
            </list>
        </field>
    </record>

    <record id="wms_sorter_api_log_view_form" model="ir.ui.view">
        <field name="name">wms.sorter.api.log.view.form</field>
        <field name="model">wms.sorter.api.log</field>
        <field name="arch" type="xml">
            <form string="API Log" create="false" edit="false">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="create_date"/>
                            <field name="name"/>
                            <field name="method"/>
                            <field name="ip_address"/>
                        </group>
                        <group>
                            <field name="status_code"/>
                            <field name="error_message" invisible="not error_message"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request Payload" name="request">
                            <field name="request_payload" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                        <page string="Response Payload" name="response">
                            <field name="response_payload" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wms_sorter_api_log_view_search" model="ir.ui.view">
        <field name="name">wms.sorter.api.log.view.search</field>
        <field name="model">wms.sorter.api.log</field>
        <field name="arch" type="xml">
            <search string="Search API Logs">
                <field name="name"/>
                <field name="ip_address"/>
                <field name="status_code"/>
                <filter string="Errors" name="errors" domain="[('state', '=', 'error')]"/>
                <filter string="Success" name="success" domain="[('state', '=', 'success')]"/>
                <group expand="0" string="Group By">
                    <filter string="Endpoint" name="group_by_name" context="{'group_by': 'name'}"/>
                    <filter string="Status Code" name="group_by_status" context="{'group_by': 'status_code'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_wms_sorter_api_log" model="ir.actions.act_window">
        <field name="name">API Audit Logs</field>
        <field name="res_model">wms.sorter.api.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="wms_sorter_api_log_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No API logs found!
            </p>
            <p>
                All interactions with the WMS Sorter FastAPI will be logged here.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_wms_sorter_api_log"
              name="API Logs"
              parent="wms_sorter_api.menu_wms_sorter_root"
              action="action_wms_sorter_api_log"
              sequence="100"/>

</odoo>
