<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ─────────────────────────────────────────────── -->
        <!-- List view                                       -->
        <!-- ─────────────────────────────────────────────── -->
        <record id="wms_sorter_log_view_list" model="ir.ui.view">
            <field name="name">wms.sorter.log.list</field>
            <field name="model">wms.sorter.log</field>
            <field name="arch" type="xml">
                <list string="Sorter Event Log" decoration-danger="level == 'error'" decoration-warning="level == 'warning'">
                    <field name="create_date" string="Date"/>
                    <field name="wave_no"/>
                    <field name="sku"/>
                    <field name="barcode"/>
                    <field name="quantity"/>
                    <field name="chute"/>
                    <field name="status"/>
                    <field name="direction"/>
                    <field name="level"/>
                    <field name="batch_id"/>
                </list>
            </field>
        </record>

        <!-- ─────────────────────────────────────────────── -->
        <!-- Form view                                       -->
        <!-- ─────────────────────────────────────────────── -->
        <record id="wms_sorter_log_view_form" model="ir.ui.view">
            <field name="name">wms.sorter.log.form</field>
            <field name="model">wms.sorter.log</field>
            <field name="arch" type="xml">
                <form string="Sorter Event" create="false" edit="false">
                    <sheet>
                        <group>
                            <group string="Event">
                                <field name="wave_no"/>
                                <field name="batch_id"/>
                                <field name="direction"/>
                                <field name="level"/>
                                <field name="status"/>
                            </group>
                            <group string="Product">
                                <field name="sku"/>
                                <field name="barcode"/>
                                <field name="quantity"/>
                                <field name="chute"/>
                            </group>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ─────────────────────────────────────────────── -->
        <!-- Search view                                     -->
        <!-- ─────────────────────────────────────────────── -->
        <record id="wms_sorter_log_view_search" model="ir.ui.view">
            <field name="name">wms.sorter.log.search</field>
            <field name="model">wms.sorter.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="wave_no"/>
                    <field name="sku"/>
                    <field name="barcode"/>
                    <filter string="Errors" name="errors" domain="[('level','=','error')]"/>
                    <filter string="Warnings" name="warnings" domain="[('level','=','warning')]"/>
                    <filter string="Inbound" name="inbound" domain="[('direction','=','in')]"/>
                    <filter string="Outbound" name="outbound" domain="[('direction','=','out')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Wave" name="group_wave" context="{'group_by': 'wave_no'}"/>
                        <filter string="Level" name="group_level" context="{'group_by': 'level'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ─────────────────────────────────────────────── -->
        <!-- Action                                          -->
        <!-- ─────────────────────────────────────────────── -->
        <record id="action_wms_sorter_log" model="ir.actions.act_window">
            <field name="name">Sorter Event Log</field>
            <field name="res_model">wms.sorter.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="wms_sorter_log_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No sorter events recorded yet.
                </p>
                <p>
                    Events are created automatically when the sorter equipment
                    pushes status updates to Odoo.
                </p>
            </field>
        </record>

        <!-- ─────────────────────────────────────────────── -->
        <!-- Menu                                            -->
        <!-- ─────────────────────────────────────────────── -->
        <menuitem
            id="menu_wms_sorter_root"
            name="Sorter API"
            parent="stock.menu_warehouse_config"
            sequence="100"/>

        <menuitem
            id="menu_wms_sorter_log"
            name="Event Log"
            parent="menu_wms_sorter_root"
            action="action_wms_sorter_log"
            sequence="10"/>

    </data>
</odoo>
