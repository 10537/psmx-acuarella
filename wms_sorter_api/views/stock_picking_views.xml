<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_picking_form_inherit_sorter" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.sorter</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="assigned_chute_id" readonly="1" invisible="picking_type_code != 'outgoing'"/>
                <field name="is_waiting_chute" readonly="1" invisible="not is_waiting_chute"/>
            </xpath>
        </field>
    </record>

    <record id="vpicktree_inherit_sorter" model="ir.ui.view">
        <field name="name">stock.picking.list.inherit.sorter</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="assigned_chute_id" optional="show"/>
                <field name="is_waiting_chute" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
