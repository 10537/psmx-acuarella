<odoo>
    <record id="view_delivery_carrier_form_servientrega" model="ir.ui.view">
        <field name="name">delivery.carrier.form.servientrega</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">

            
            <xpath expr="//page[@name='destination']" position="before">

                <page string="Servientrega" invisible="delivery_type != 'servientrega'">

                    <group string="Modo">
                        <field name="servientrega_mode"/>
                    </group>

                    <group string="Endpoints">
                        <field name="servientrega_url_guias"/>
                        <field name="servientrega_url_auth"/>
                        <field name="servientrega_url_cotizador"/>
                    </group>

                    <group string="Credenciales">
                        <field name="servientrega_user"/>
                        <field name="servientrega_password" password="True"/>
                        <field name="servientrega_cod_facturacion"/>
                    </group>

                    <group string="Producto">
                        <field name="servientrega_id_producto"/>
                        <field name="servientrega_nombre_cargue"/>
                    </group>

                </page>

            </xpath>

        </field>
    </record>
</odoo>
